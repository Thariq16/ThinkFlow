{
  "name": "thinkflow-functions",
  "version": "1.0.0",
  "description": "ThinkFlow Cloud Functions — voice decomposition, KB recalibration, Stripe billing",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "@google-cloud/vertexai": "^1.4.0",
    "stripe": "^14.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/node": "^20.0.0"
  },
  "private": true
}
